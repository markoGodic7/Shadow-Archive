# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/duel_archive

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# YGOPRODeck API (no key needed, but rate limits apply)
YGOPRODECK_API_BASE_URL=https://db.ygoprodeck.com/api/v7/